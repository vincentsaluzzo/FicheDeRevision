# Environment variables for Docker Compose
# Copy this file to .env and fill in your API keys

# OpenAI API Key (required for OpenAI features)
OPENAI_API_KEY=your_openai_api_key_here

# Mistral AI API Key (required for Mistral features)
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: Override default port
# PORT=3000

# Optional: Override data paths (useful for custom NAS mounting)
# DATABASE_PATH=/app/data/database/database.sqlite
# UPLOADS_DIR=/app/data/uploads

# Optional: AI Model Configuration
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_OUTPUT_TOKENS=100000

# Debug Options (for development)
# DEBUG_AI=true

# Optional: File upload size limit (default: 10MB)
# MAX_FILE_SIZE=10485760

# Debug Options (for development)
# DEBUG_AI=true